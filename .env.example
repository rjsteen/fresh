# Backend
DATABASE_URL=ecto://postgres:postgres@localhost/finapp_dev
SECRET_KEY_BASE=<generate with: mix phx.gen.secret>
GUARDIAN_SECRET_KEY=<generate with: mix phx.gen.secret 32>
CLOAK_KEY_BASE64=<generate with: 32 random bytes | base64>
REDIS_URL=redis://localhost:6379
PHX_HOST=localhost
PORT=4000

# Bank integrations
SIMPLEFIN_SANDBOX=true
GOCARDLESS_SECRET_ID=<from GoCardless dashboard>
GOCARDLESS_SECRET_KEY=<from GoCardless dashboard>
GOCARDLESS_SANDBOX=true

# ML sidecar
ML_SIDECAR_URL=http://localhost:8001
SIDECAR_TOKEN=<generate with: openssl rand -hex 32>

# Cloudflare R2 / MinIO (local)
R2_ENDPOINT_URL=http://localhost:9000
R2_BUCKET=finapp-models
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin

# CDN base URL (where devices pull model weights from)
CDN_BASE_URL=http://localhost:9000/finapp-models

# Web app (Vite)
VITE_API_URL=http://localhost:4000
VITE_CDN_BASE_URL=http://localhost:9000/finapp-models
