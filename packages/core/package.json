{
  "name": "@fresh/core",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./db": {
      "import": "./dist/db/index.mjs",
      "require": "./dist/db/index.js",
      "types": "./dist/db/index.d.ts"
    },
    "./channels": {
      "import": "./dist/channels/index.mjs",
      "require": "./dist/channels/index.js",
      "types": "./dist/channels/index.d.ts"
    },
    "./ml": {
      "import": "./dist/ml/index.mjs",
      "require": "./dist/ml/index.js",
      "types": "./dist/ml/index.d.ts"
    },
    "./budget": {
      "import": "./dist/budget/index.mjs",
      "require": "./dist/budget/index.js",
      "types": "./dist/budget/index.d.ts"
    },
    "./cloud": {
      "import": "./dist/cloud/index.mjs",
      "require": "./dist/cloud/index.js",
      "types": "./dist/cloud/index.d.ts"
    },
    "./sync": {
      "import": "./dist/sync/index.mjs",
      "require": "./dist/sync/index.js",
      "types": "./dist/sync/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "phoenix": "^1.7.14",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/phoenix": "^1.6.7",
    "@types/react": "~18.3.28",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "sql.js": "^1.14.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  }
}
